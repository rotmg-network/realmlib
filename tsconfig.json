{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "pretty": true,
    "rootDir": "src",
    "outDir": "lib",
    "lib": ["ES2020"]
  },
  "ts-node": {
    "transpileOnly": true
  },
  "include": ["src/**/*"]
}
