  },
  "devDependencies": {
    "@types/chai": "^4.2.22",
    "@types/mocha": "^10.0.10",
    "@types/node": "^16.18.126",
    "chai": "^4.3.4",
    "mocha": "^11.7.6",
    "ts-node": "^10.9.2",
    "typedoc": "^0.22.5",
    "typescript": "^4.4.3"
  }
